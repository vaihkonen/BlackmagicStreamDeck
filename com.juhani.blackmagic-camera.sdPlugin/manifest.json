{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.juhani.blackmagic-camera",
  "Name": "Blackmagic Camera Control",
  "Version": "1.0.0.0",
  "Author": "Juhani Vaihkonen",
  "Description": "Control your Blackmagic camera directly from Stream Deck. Toggle recording, adjust ISO, shutter speed, white balance and trigger autofocus.",
  "Category": "Blackmagic Camera",
  "CategoryIcon": "imgs/plugin/category-icon",
  "Icon": "imgs/plugin/marketplace",
  "CodePath": "bin/plugin.js",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.6"
  },
  "OS": [
    {
      "Platform": "mac",
      "MinimumVersion": "10.15"
    },
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Actions": [
    {
      "Name": "Toggle Recording",
      "UUID": "com.juhani.blackmagic-camera.toggle-recording",
      "Icon": "imgs/actions/recording/icon",
      "Tooltip": "Start or stop recording on your Blackmagic camera.",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/recording/key-idle",
          "Title": "REC",
          "TitleAlignment": "bottom",
          "TitleColor": "#ffffff"
        },
        {
          "Image": "imgs/actions/recording/key-active",
          "Title": "STOP",
          "TitleAlignment": "bottom",
          "TitleColor": "#ff4444"
        }
      ],
      "PropertyInspectorPath": "ui/toggle-recording.html"
    },
    {
      "Name": "Adjust ISO",
      "UUID": "com.juhani.blackmagic-camera.adjust-iso",
      "Icon": "imgs/actions/iso/icon",
      "Tooltip": "Step ISO up or down. Use as a button (configure direction) or dial (rotate to adjust).",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/iso/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust ISO",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-iso.html"
    },
    {
      "Name": "Adjust White Balance",
      "UUID": "com.juhani.blackmagic-camera.adjust-white-balance",
      "Icon": "imgs/actions/wb/icon",
      "Tooltip": "Adjust white balance. Use as a button or dial (rotate = ±K, press = auto WB).",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/wb/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust white balance",
          "Push": "Auto white balance",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-white-balance.html"
    },
    {
      "Name": "Adjust Tint",
      "UUID": "com.juhani.blackmagic-camera.adjust-tint",
      "Icon": "imgs/actions/wb/icon",
      "Tooltip": "Adjust white balance tint (green/magenta offset, −50 to +50). Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/wb/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust tint",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-tint.html"
    },
    {
      "Name": "Adjust Shutter",
      "UUID": "com.juhani.blackmagic-camera.adjust-shutter",
      "Icon": "imgs/actions/shutter/icon",
      "Tooltip": "Step shutter speed/angle up or down. Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/shutter/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust shutter",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-shutter.html"
    },
    {
      "Name": "Adjust Iris",
      "UUID": "com.juhani.blackmagic-camera.adjust-iris",
      "Icon": "imgs/actions/iris/icon",
      "Tooltip": "Open or close the lens iris. Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/iso/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust iris",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-iris.html"
    },
    {
      "Name": "Adjust Zoom",
      "UUID": "com.juhani.blackmagic-camera.adjust-zoom",
      "Icon": "imgs/actions/zoom/icon",
      "Tooltip": "Zoom in or out. Use as a button or dial (requires motorised zoom lens).",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/iso/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust zoom",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-zoom.html"
    },
    {
      "Name": "Auto Focus",
      "UUID": "com.juhani.blackmagic-camera.auto-focus",
      "Icon": "imgs/actions/focus/icon",
      "Tooltip": "Trigger auto focus on your Blackmagic camera (requires electronic lens).",
      "Controllers": ["Keypad"],
      "States": [
        {
          "Image": "imgs/actions/focus/key",
          "TitleAlignment": "middle"
        }
      ],
      "PropertyInspectorPath": "ui/auto-focus.html"
    },
    {
      "Name": "Adjust Gain",
      "UUID": "com.juhani.blackmagic-camera.adjust-gain",
      "Icon": "imgs/actions/iso/icon",
      "Tooltip": "Step gain (dB) up or down. Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/iso/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust gain",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-gain.html"
    },
    {
      "Name": "Manual Focus",
      "UUID": "com.juhani.blackmagic-camera.adjust-focus",
      "Icon": "imgs/actions/focus/icon",
      "Tooltip": "Pull focus near or far. Use as a button or dial (dial press = auto focus).",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/focus/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Pull focus",
          "Push": "Auto focus",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-focus.html"
    },
    {
      "Name": "Adjust Saturation",
      "UUID": "com.juhani.blackmagic-camera.adjust-saturation",
      "Icon": "imgs/actions/wb/icon",
      "Tooltip": "Adjust colour saturation (0–2, default 1). Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/wb/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust saturation",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-saturation.html"
    },
    {
      "Name": "Adjust Contrast",
      "UUID": "com.juhani.blackmagic-camera.adjust-contrast",
      "Icon": "imgs/actions/wb/icon",
      "Tooltip": "Adjust contrast (0–2, default 1). Use as a button or dial.",
      "Controllers": ["Keypad", "Encoder"],
      "States": [
        {
          "Image": "imgs/actions/wb/key",
          "TitleAlignment": "middle"
        }
      ],
      "Encoder": {
        "layout": "$A1",
        "TriggerDescription": {
          "Rotate": "Adjust contrast",
          "Push": "Refresh",
          "Touch": "Refresh"
        }
      },
      "PropertyInspectorPath": "ui/adjust-contrast.html"
    }
  ]
}
